# OAS MCP Server — environment variable reference
# Copy to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored so secrets never end up in version control.

# Transport: "stdio" (default, for Claude Desktop) or "http" (remote clients)
OAS_TRANSPORT=http

# HTTP transport — host and port (only used when OAS_TRANSPORT=http)
OAS_HOST=127.0.0.1
OAS_PORT=8000

# Artifact storage root — artifacts are saved under {OAS_DATA_DIR}/{session_id}/
# Default: ./oas_data/artifacts/  |  In Docker: /data/artifacts
OAS_DATA_DIR=./oas_data/artifacts

# Keycloak auth (only used when OAS_TRANSPORT=http)
# Leave KEYCLOAK_ISSUER_URL empty to disable authentication.
KEYCLOAK_ISSUER_URL=https://your-keycloak.railway.app/realms/oas
KEYCLOAK_CLIENT_ID=oas-mcp
KEYCLOAK_CLIENT_SECRET=
RESOURCE_SERVER_URL=http://localhost:8000
