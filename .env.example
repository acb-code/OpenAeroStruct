# OAS MCP Server — environment variable reference
# Copy to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored so secrets never end up in version control.

# Transport: "stdio" (default, for Claude Desktop) or "http" (remote clients)
OAS_TRANSPORT=http

# HTTP transport — host and port (only used when OAS_TRANSPORT=http)
OAS_HOST=127.0.0.1
OAS_PORT=8000

# Artifact storage root — runs are saved under {OAS_DATA_DIR}/{user}/{project}/{session_id}/
# Default: ./oas_data/  |  In Docker (bind mount): /data
OAS_DATA_DIR=./oas_data

# User identity used to namespace artifact storage (optional)
# Defaults to the OS login name; override here if running as a shared service user.
# OAS_USER=myname

# OIDC auth (only used when OAS_TRANSPORT=http)
# Works with any OIDC provider: Authentik, Keycloak, Auth0, etc.
# Leave OIDC_ISSUER_URL empty to disable authentication.
OIDC_ISSUER_URL=https://auth.example.com/application/o/oas-mcp/
OIDC_CLIENT_ID=oas-mcp
OIDC_CLIENT_SECRET=
RESOURCE_SERVER_URL=http://localhost:8000

# Legacy Keycloak env vars (KEYCLOAK_ISSUER_URL, KEYCLOAK_CLIENT_ID,
# KEYCLOAK_CLIENT_SECRET) are still accepted as fallbacks.
